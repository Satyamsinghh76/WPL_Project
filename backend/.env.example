# Environment Variables Template
# Copy this to .env and fill in your actual values for local development

# Django Settings
SECRET_KEY=your-django-secret-key

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# For Render: Supabase Postgres connection string
# DATABASE_URL=postgresql://postgres:PASSWORD@db.REF.supabase.co:5432/postgres

# CORS Settings
# Update CORS_ALLOWED_ORIGINS to your frontend URLs (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Supabase Configuration (required for OAuth login)
# Get these from Supabase dashboard: Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Email (console backend for local dev, SMTP for production)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-gmail-app-password
# DEFAULT_FROM_EMAIL=Scholr <your-email@gmail.com>

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:5173
