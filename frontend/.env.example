# Frontend Environment Variables
# For Vite, variables must be prefixed with VITE_ to be exposed to the browser

# Backend API URL
# Local: VITE_API_URL=http://localhost:8000
# Production (Render): VITE_API_URL=https://your-app.onrender.com
VITE_API_URL=http://localhost:8000

# Supabase Configuration (required for OAuth login)
# Get these from Supabase dashboard: Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
